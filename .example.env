# dispatch — example environment
# Copy to .env (or export these) and fill in the required values.

# --- required ---
# Random url-safe token [A-Za-z0-9_-], >=24 chars. Generate with:
#   openssl rand -hex 24
ADMIN_URL_SECRET=replace-with-openssl-rand-hex-24

# Admin password — set EXACTLY ONE of these:
# Preferred: a bcrypt hash. Generate with:
#   htpasswd -bnBC 12 "" 'your-password' | tr -d ':\n' | sed 's/^\$2y/\$2a/'
ADMIN_PASSWORD_HASH=
# Convenience: plaintext, hashed with bcrypt cost 12 at startup.
ADMIN_PASSWORD=

# --- optional ---
# Bind loopback only; Cloudflare Tunnel connects here.
LISTEN_ADDR=127.0.0.1:8080

# >=32 chars; if unset, a random one is generated per start (sessions won't
# survive restart). Generate with: openssl rand -hex 32
SESSION_SECRET=

# Blob storage and metadata.
STORAGE_DIR=./data/files
DB_PATH=./data/dispatch.db

# 100 MiB — the Cloudflare free-tier request body cap. Raise only if your
# Cloudflare plan allows larger uploads.
MAX_UPLOAD_BYTES=104857600

# Session cookie lifetime (seconds). 43200 = 12h.
SESSION_MAX_AGE=43200

# How often the reaper purges expired files (seconds). 0 disables; expired links
# still 404 immediately, but blobs are not auto-deleted.
REAPER_INTERVAL=3600
